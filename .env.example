# ----------------------------------------------------------------------------
# Database (used by apps/api and packages/db drizzle-kit)
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas

# ----------------------------------------------------------------------------
# Better Auth (server lives in apps/api)
# ----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-char-or-longer-secret
# Public URL of the NestJS API (auth server)
BETTER_AUTH_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# URLs / ports
# ----------------------------------------------------------------------------
API_PORT=3001
# Web app origin — used for CORS + Better Auth trustedOrigins
WEB_URL=http://localhost:3000
# Consumed by apps/web (auth client + api client point here)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Production only: set to share the session cookie across subdomains,
# e.g. COOKIE_DOMAIN=.yourapp.com when web=yourapp.com and api=api.yourapp.com
# COOKIE_DOMAIN=

# ----------------------------------------------------------------------------
# Google OAuth (optional — handled by the API now)
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# ----------------------------------------------------------------------------
# RBAC fallback: comma-separated emails that get the admin role
# (primary source of truth is now the `role` column managed by the
#  Better Auth admin plugin — this list is a convenience fallback)
# ----------------------------------------------------------------------------
AUTH_ADMIN_EMAILS=admin@test.com
NEXT_PUBLIC_AUTH_ADMIN_EMAILS=admin@test.com

# ----------------------------------------------------------------------------
# Web extras (see apps/web/.env.example for the full list)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_MODE=true
