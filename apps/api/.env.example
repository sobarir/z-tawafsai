# apps/api reads the monorepo root .env automatically.
# Use this file only if you want API-specific overrides.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3001
# API_PORT=3001
# WEB_URL=http://localhost:3000
# Flyer uploads (POST /api/uploads/flyer):
# API_PUBLIC_URL=http://localhost:3001      # origin used to build stored file URLs
# UPLOADS_DIR=uploads                        # relative to apps/api cwd
# MAX_UPLOAD_BYTES=5242880                   # 5 MiB per file
