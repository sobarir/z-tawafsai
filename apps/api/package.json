{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "generate:api": "nest build && node dist/openapi.js",
    "clean": "rm -rf dist .turbo openapi.json"
  },
  "dependencies": {
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^8.2.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@repo/auth": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/shared": "workspace:*",
    "@thallesp/nestjs-better-auth": "^2.7.0",
    "better-auth": "1.6.13",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.4.0",
    "nestjs-pino": "^4.4.0",
    "nestjs-zod": "^5.4.0",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@types/node": "^22.15.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.9.2",
    "vitest": "4.1.7"
  }
}
