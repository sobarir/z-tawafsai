# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
# Public app URL (used by SEO metadata, sitemap, canonical URLs).
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Backend API (NestJS) — owns Better Auth + Drizzle/Postgres
# ----------------------------------------------------------------------------
# The auth client and apiFetch both point here.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# Google OAuth toggle (credentials now live in the API's env)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# ----------------------------------------------------------------------------
# RBAC fallback: comma-separated emails treated as admins client-side.
# The real role lives in the DB (Better Auth admin plugin) — keep in sync
# with AUTH_ADMIN_EMAILS in the root .env.
# ----------------------------------------------------------------------------
AUTH_ADMIN_EMAILS=admin@test.com
NEXT_PUBLIC_AUTH_ADMIN_EMAILS=admin@test.com

# ----------------------------------------------------------------------------
# Demo mode: renders click-to-fill demo credentials on the login page and
# auto-registers seed accounts on first sign-in. Disable for production.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_MODE=true

# ----------------------------------------------------------------------------
# Optional: Sentry / Upstash rate limiting
# ----------------------------------------------------------------------------
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
