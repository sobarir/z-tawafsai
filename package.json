{
  "name": "saas-starter",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "generate:api": "turbo run generate:api",
    "db:generate": "turbo run db:generate --filter=@repo/db",
    "db:migrate": "turbo run db:migrate --filter=@repo/db",
    "db:push": "turbo run db:push --filter=@repo/db",
    "db:studio": "pnpm --filter @repo/db db:studio",
    "clean": "turbo run clean && rm -rf node_modules",
    "check:backbone": "node scripts/check-backbone.mjs",
    "prepare": "lefthook install || true",
    "check:instructions": "node scripts/check-instructions.mjs",
    "check:dupes": "jscpd apps packages"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "jscpd": "^5.0.12",
    "lefthook": "^2.0.0",
    "turbo": "^2.5.0",
    "yaml": "^2.6.0"
  },
  "packageManager": "pnpm@10.12.1",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
